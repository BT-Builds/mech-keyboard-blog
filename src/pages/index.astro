---
const articles = [
  { slug: 'best-keyboards-typing', title: 'Best Mechanical Keyboards for Typing in 2026', desc: 'Our top picks for typists who want accuracy, comfort, and switches that hold up over millions of keystrokes.' }
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mechanical Keyboard Reviews & Buying Guides</title>
  <meta name="description" content="Honest reviews and buying guides for mechanical keyboards. Budget picks, gaming setups, silent office keyboards, and everything in between.">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #1a1a1a; background: #fff; }
    header { border-bottom: 1px solid #e5e5e5; padding: 1.5rem 2rem; }
    header h1 { font-size: 1.4rem; font-weight: 700; }
    header p { color: #666; font-size: 0.9rem; margin-top: 0.25rem; }
    main { max-width: 720px; margin: 0 auto; padding: 3rem 2rem; }
    h2 { font-size: 1.1rem; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1.5rem; }
    .article { border: 1px solid #e5e5e5; border-radius: 8px; padding: 1.5rem; margin-bottom: 1rem; text-decoration: none; display: block; color: inherit; transition: border-color 0.15s; }
    .article:hover { border-color: #333; }
    .article h3 { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; }
    .article p { color: #555; font-size: 0.9rem; line-height: 1.5; }
    footer { border-top: 1px solid #e5e5e5; text-align: center; padding: 2rem; color: #999; font-size: 0.85rem; }
  </style>
</head>
<body>
  <header>
    <h1>KeyboardPicks</h1>
    <p>Mechanical keyboard reviews and buying guides</p>
  </header>
  <main>
    <h2>Latest Guides</h2>
    {articles.map(a => (
      <a href={} class="article">
        <h3>{a.title}</h3>
        <p>{a.desc}</p>
      </a>
    ))}
  </main>
  <footer>KeyboardPicks — honest reviews, no fluff</footer>
</body>
</html>
